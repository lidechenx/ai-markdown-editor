{
  "name": "ai-markdown-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Vue 3 + CodeMirror 6 的本地优先 Markdown 编辑器：实时预览、粘贴图片、语法速查与可选 AI 润色。",
  "keywords": [
    "markdown",
    "markdown-editor",
    "vue",
    "codemirror",
    "codemirror6",
    "vite",
    "typescript",
    "markdown-it",
    "wysiwyg",
    "note-taking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lidechenx/ai-markdown-editor.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "codemirror": "^6.0.2",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "vue": "^3.5.34",
    "vue-codemirror6": "^1.5.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9",
    "vue-tsc": "^3.2.8"
  }
}
